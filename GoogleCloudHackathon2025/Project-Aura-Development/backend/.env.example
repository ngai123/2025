# Project Aura Backend - .env example
# Copy this file to `.env` in the `backend/` directory and fill in values.
# This template matches `app.database.Settings` and `test_connection.py` expectations.

# Core Database Settings (used by app.database.Settings)
DATABASE_HOST=your_db_host
DATABASE_PORT=5432
DATABASE_NAME=your_database_name
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password

# Optional App Settings
SECRET_KEY=temporary-dev-key-change-later
ENVIRONMENT=development

# CORS for local frontend (currently hard-coded in app/main.py)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json

# Google Cloud Storage Settings
GCS_BUCKET_NAME=project-aura-images
GCS_UPLOAD_PREFIX=profile-pictures

# Google Gemini AI API Settings
GEMINI_API_KEY=your-gemini-api-key-here

# AURA Dating App - Gmail API Configuration Example
# Enable Gmail API
GMAIL_API_ENABLED=true
GMAIL_AUTH_TYPE=oauth
GMAIL_OAUTH_CREDENTIALS_FILE=app/config/gmail-oauth-credentials.json
GMAIL_TOKEN_FILE=app/config/token.json
GMAIL_SENDER_EMAIL=aura.aidatingapp@gmail.com
GMAIL_SENDER_NAME=AURA Dating App

# ============= GEMINI AI (Optional) =============
# Used for personality analysis and RAG-based relationship advice
GEMINI_API_KEY=your-gemini-api-key-here
# Alternative: GOOGLE_API_KEY can also be used (RAG service checks both)

# Optional: Not used by `app.database.Settings` currently. Leave commented or remove.
# DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}
# ASYNC_DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}