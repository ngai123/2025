# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).
#
# For more information, run:
#   $ gcloud topic gcloudignore
#
.gcloudignore
# If you would like to upload your .git directory, .gitignore file or files
# from your .gitignore file, remove the corresponding line
# below:
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments (CRITICAL - don't upload!)
venv/
env/
ENV/
.venv
.env.local
.env.*.local

# Environment files
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation
*.md
!README.md
docs/

# Database
*.db
*.sqlite
*.sqlite3

# Scripts and tools (not needed in production)
scripts/
Database Scripts/
Google Cloud SQL/
test_*.py
populate_*.py
add_*.py
run_migration.py

# Logs
*.log
logs/

# Git
.gitattributes

# CI/CD
.gitlab-ci.yml
.github/

# Credentials (should be mounted as secrets)
credentials/*.json
*.pem
*.key

# Misc
.DS_Store
Thumbs.db
*.bak

# RAG data - only needed if you want to rebuild vector store
# Comment these out if you need to rebuild in Cloud Build
data/
# vector_store/ is now copied to Docker image for RAG functionality
Summaries/

# Cloud build artifacts
cloudbuild.yaml
.gcloudignore
